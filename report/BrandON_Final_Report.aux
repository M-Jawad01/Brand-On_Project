\@writefile{toc}{\contentsline {subsection}{\numberline {2.3}Acceptance Criteria (Selected)}{6}{subsection.2.3}\protected@file@percent }
\@writefile{toc}{\contentsline {section}{\numberline {3}System Architecture and Design}{6}{section.3}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {3.1}System Architecture Overview}{6}{subsection.3.1}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces System Architecture Diagram. The browser communicates with the Next.js server over HTTP. The middleware layer intercepts all \texttt  {/admin/*} routes and enforces cookie-based authentication before any server component or API route is reached. The \texttt  {lib/} modules (prisma.ts, pricing.ts, validation.ts) are shared utilities consumed by API routes and server components alike. All database operations go through Prisma ORM to PostgreSQL running in a Docker container.}}{7}{figure.caption.2}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:arch}{{1}{7}{System Architecture Diagram. The browser communicates with the Next.js server over HTTP. The middleware layer intercepts all \texttt {/admin/*} routes and enforces cookie-based authentication before any server component or API route is reached. The \texttt {lib/} modules (prisma.ts, pricing.ts, validation.ts) are shared utilities consumed by API routes and server components alike. All database operations go through Prisma ORM to PostgreSQL running in a Docker container}{figure.caption.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Class and Component Diagram. The diagram shows the five distinct layers of the system: the React Component Layer (Header, Footer, AdminLogin), the API Routes HTTP Layer (POST /api/admin/login), the Validation Layer (ValidationHelpers module with OrderInput and MaterialInput interfaces), the Pricing Layer implementing the Strategy Pattern (PricingStrategy interface, three concrete strategies, and PriceCalculator context), and the Database Layer using the Singleton Pattern (DatabaseClient wrapping PrismaClient). Arrows indicate delegation and composition relationships between layers.}}{8}{figure.caption.3}\protected@file@percent }
\newlabel{fig:class}{{2}{8}{Class and Component Diagram. The diagram shows the five distinct layers of the system: the React Component Layer (Header, Footer, AdminLogin), the API Routes HTTP Layer (POST /api/admin/login), the Validation Layer (ValidationHelpers module with OrderInput and MaterialInput interfaces), the Pricing Layer implementing the Strategy Pattern (PricingStrategy interface, three concrete strategies, and PriceCalculator context), and the Database Layer using the Singleton Pattern (DatabaseClient wrapping PrismaClient). Arrows indicate delegation and composition relationships between layers}{figure.caption.3}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {3.2}Database Design}{9}{subsection.3.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Entity Relationship Diagram. Six tables constitute the schema: \texttt  {Material} (products with pricing), \texttt  {Order} (customer submissions with foreign key to Material), \texttt  {OrderStatusHistory} (audit log of every status change), \texttt  {Admin} (shop staff accounts with bcrypt-hashed passwords), \texttt  {GalleryItem} (portfolio images uploaded by admins), and \texttt  {CompanyProfile} (a single-row settings table for shop contact details and social links). The diagram shows all primary keys, foreign key relationships, and field types.}}{9}{figure.caption.4}\protected@file@percent }
\newlabel{fig:erd}{{3}{9}{Entity Relationship Diagram. Six tables constitute the schema: \texttt {Material} (products with pricing), \texttt {Order} (customer submissions with foreign key to Material), \texttt {OrderStatusHistory} (audit log of every status change), \texttt {Admin} (shop staff accounts with bcrypt-hashed passwords), \texttt {GalleryItem} (portfolio images uploaded by admins), and \texttt {CompanyProfile} (a single-row settings table for shop contact details and social links). The diagram shows all primary keys, foreign key relationships, and field types}{figure.caption.4}{}}
\@writefile{toc}{\contentsline {subsubsection}{\numberline {3.2.1}Relationships}{9}{subsubsection.3.2.1}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {4}{\ignorespaces Database Relationship Summary}}{9}{table.caption.5}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {3.3}Sequence Diagrams}{10}{subsection.3.3}\protected@file@percent }
\@writefile{toc}{\contentsline {subsubsection}{\numberline {3.3.1}Place Order Flow}{10}{subsubsection.3.3.1}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Place Order Sequence Diagram. The sequence begins when the customer fills the order form and submits it. The browser sends a POST request to \texttt  {/api/orders}. The API route first calls \texttt  {validateOrderInput()}; any validation failure returns a 400 response immediately. For valid input, the server fetches the material price from the database and recalculates the total price on the server side, ignoring any value submitted by the client. Prisma creates the order record, generates a human-readable order number in the format BON-YYYYMMDD-NNN, and the confirmation is returned to the customer.}}{10}{figure.caption.6}\protected@file@percent }
\newlabel{fig:order-seq}{{4}{10}{Place Order Sequence Diagram. The sequence begins when the customer fills the order form and submits it. The browser sends a POST request to \texttt {/api/orders}. The API route first calls \texttt {validateOrderInput()}; any validation failure returns a 400 response immediately. For valid input, the server fetches the material price from the database and recalculates the total price on the server side, ignoring any value submitted by the client. Prisma creates the order record, generates a human-readable order number in the format BON-YYYYMMDD-NNN, and the confirmation is returned to the customer}{figure.caption.6}{}}
\@writefile{toc}{\contentsline {subsubsection}{\numberline {3.3.2}Admin Login Flow}{11}{subsubsection.3.3.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Admin Login Sequence Diagram. When the admin navigates to \texttt  {/admin}, the middleware reads the \texttt  {admin\_token} cookie. If the cookie is absent, the request is redirected to \texttt  {/admin/login}. The admin submits their password via a POST request to \texttt  {/api/admin/login}. The server compares the submitted value against the \texttt  {ADMIN\_SECRET} environment variable. On success, an httpOnly cookie named \texttt  {admin\_token} is set and the admin is redirected to the dashboard. All subsequent requests to \texttt  {/admin/*} routes repeat this cookie check through the middleware; the dashboard pages themselves perform no additional authentication logic.}}{11}{figure.caption.7}\protected@file@percent }
\newlabel{fig:login-seq}{{5}{11}{Admin Login Sequence Diagram. When the admin navigates to \texttt {/admin}, the middleware reads the \texttt {admin\_token} cookie. If the cookie is absent, the request is redirected to \texttt {/admin/login}. The admin submits their password via a POST request to \texttt {/api/admin/login}. The server compares the submitted value against the \texttt {ADMIN\_SECRET} environment variable. On success, an httpOnly cookie named \texttt {admin\_token} is set and the admin is redirected to the dashboard. All subsequent requests to \texttt {/admin/*} routes repeat this cookie check through the middleware; the dashboard pages themselves perform no additional authentication logic}{figure.caption.7}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {3.4}Use Case Diagram}{12}{subsection.3.4}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Use Case Diagram for the BrandON Platform. The diagram is partitioned into three zones: Public Zone (customer-facing actions), Admin Zone (authenticated management actions), and System Automated Actions (middleware-triggered operations). Customer use cases include browsing materials, viewing gallery, placing orders, and contacting the shop. Admin use cases cover the full CRUD lifecycle for materials, orders, and gallery items, plus company profile management. The ``Place Order'' use case includes ``Validate Order Input'' and ``Calculate Price'' as included sub-flows. All Admin Zone use cases include authentication via middleware as a prerequisite, shown with \textless \textless include\textgreater \textgreater \ relationships.}}{12}{figure.caption.8}\protected@file@percent }
\newlabel{fig:usecase}{{6}{12}{Use Case Diagram for the BrandON Platform. The diagram is partitioned into three zones: Public Zone (customer-facing actions), Admin Zone (authenticated management actions), and System Automated Actions (middleware-triggered operations). Customer use cases include browsing materials, viewing gallery, placing orders, and contacting the shop. Admin use cases cover the full CRUD lifecycle for materials, orders, and gallery items, plus company profile management. The ``Place Order'' use case includes ``Validate Order Input'' and ``Calculate Price'' as included sub-flows. All Admin Zone use cases include authentication via middleware as a prerequisite, shown with \textless \textless include\textgreater \textgreater \ relationships}{figure.caption.8}{}}
