\newlabel{fig:jest-unit-1}{{7}{24}{Unit Test Output (1 of 3): \texttt {StandardPricing} strategy executing within the Jest parallel runner. Test cases confirm correct area-based price calculation, linear scaling with quantity, decimal dimension handling, and zero-value edge cases}{figure.caption.21}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces Unit Test Output (2 of 3): \texttt  {BulkDiscountPricing} strategy. Test cases verify that no discount is applied below a quantity of five, a 10\% discount is applied at exactly five units, and the discount continues to apply for quantities greater than five.}}{24}{figure.caption.22}\protected@file@percent }
\newlabel{fig:jest-unit-2}{{8}{24}{Unit Test Output (2 of 3): \texttt {BulkDiscountPricing} strategy. Test cases verify that no discount is applied below a quantity of five, a 10\% discount is applied at exactly five units, and the discount continues to apply for quantities greater than five}{figure.caption.22}{}}
