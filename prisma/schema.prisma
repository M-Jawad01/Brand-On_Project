generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model Material {
  id           String   @id @default(cuid())
  name         String   @unique
  description  String?  @db.Text
  pricePerSqFt Float
  imageUrl     String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  orders       Order[]

  @@map("materials")
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique @default(cuid())
  customerName    String
  customerPhone   String
  customerEmail   String?
  customerAddress String?     @db.Text
  materialId      String
  material        Material    @relation(fields: [materialId], references: [id])
  widthFt         Float
  heightFt        Float
  quantity        Int         @default(1)
  totalPrice      Float
  designFileUrl   String?
  specialNotes    String?     @db.Text
  status          OrderStatus @default(PENDING)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@map("orders")
}

model GalleryItem {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  imageUrl    String
  category    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("gallery_items")
}

model CompanyProfile {
  id             String   @id @default(cuid())
  companyName    String   @default("BrandON")
  tagline        String?
  about          String?  @db.Text
  location       String?
  phone          String?
  email          String?
  whatsappNumber String?
  facebookUrl    String?
  instagramUrl   String?
  businessHours  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("company_profile")
}